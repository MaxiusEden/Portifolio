---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import Skills from '../components/Skills.astro';

const botaniaTubesDescription = `Biblioteca Java open-source desenvolvida para habilitar interoperabilidade entre sistemas de transporte de fluidos de terceiros e o Petal Apothecary do Botania. Atingiu +539.000 downloads na CurseForge com ~50.000 usuários ativos diários.`;
---

<Layout title="Filipe Machado | Desenvolvedor de Software">
    <main class="container mx-auto px-4">
        
        <section class="hero text-center py-24 sm:py-32">
            <img
                src="/foto-perfil.jpg"
                alt="Foto de Perfil de Filipe Machado"
                class="w-32 h-32 rounded-full mx-auto mb-8 border-4 border-cyan-400/50 object-cover shadow-lg"
            />
            <h1 class="text-5xl sm:text-7xl font-black tracking-tighter bg-clip-text text-transparent bg-gradient-to-r from-white to-gray-500">
                Filipe Pereira Machado
            </h1>
            <p class="text-xl sm:text-2xl mt-4 text-gray-300">Desenvolvedor de Software · Java · Android · React</p>
            <p class="max-w-2xl mx-auto mt-6 text-gray-400">
                Estudante de Engenharia da Computação (PUC-GO) com experiência prática em projetos open-source de larga escala, aplicações mobile multiplataforma e automação de processos. Criador do BotaniaTubes — 539.000+ downloads na CurseForge.
            </p>
            <div class="mt-10 flex flex-col sm:flex-row justify-center gap-4">
                <a href="#projetos" class="bg-cyan-400 text-gray-900 font-bold py-3 px-8 rounded-lg hover:bg-cyan-300 transition-all duration-300 transform hover:scale-105">
                    Ver Projetos
                </a>
                <a href="mailto:filipepm17@gmail.com" class="bg-gray-800/50 border border-gray-700 text-gray-200 font-bold py-3 px-8 rounded-lg hover:bg-gray-700 hover:border-gray-600 transition-all duration-300">
                    Entrar em Contato
                </a>
            </div>
        </section>

        <Skills />

        <section id="projetos" class="py-24">
            <h2 class="text-4xl sm:text-5xl font-bold text-center mb-16">Projetos em Destaque</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                
                <ProjectCard
                    title="BotaniaTubes"
                    description={botaniaTubesDescription}
                    descriptionId="botania-description"
                    tags={['Java', 'Forge API', 'Gradle', 'Git']}
                    githubUrl="https://github.com/MaxiusEden/BotaniaTubes"
                    liveUrl="https://www.curseforge.com/minecraft/mc-mods/botaniatubes"
                    imageUrl="/projeto-botaniatubes.png"
                />

                <ProjectCard
                    title="Scout Volleyball"
                    description="Aplicativo multiplataforma (Web e Android) de análise estatística de voleibol para técnicos e analistas esportivos. Backend serverless com Supabase, in-app purchases via Google Play e arquitetura offline-first. Publicado no Google Play em alpha fechado."
                    tags={['React', 'Next.js', 'TypeScript', 'Supabase', 'Capacitor', 'PostgreSQL']}
                    githubUrl="https://github.com/MaxiusEden/scout-volleyball"
                    imageUrl="/projeto-scout.png"
                />

                <ProjectCard
                    title="Sistema Android para Inventário Industrial"
                    description="Aplicação Android para dispositivos Honeywell no setor de conveniência de postos de combustível. Integração nativa com leitor de código de barras (EAN) e persistência de dados para controle de estoque. Resultado: +76% de eficiência operacional."
                    tags={['Java', 'Android SDK', 'Maven', 'Android Studio']}
                    imageUrl="/projeto-inventario.png"
                />

            </div>
        </section>
    </main>

    <script>
    async function fetchCurseForgeDownloads() {
        try {
            const modId = '1183923';
            const response = await fetch(`https://img.shields.io/curseforge/dt/${modId}.json`);
            if (!response.ok) throw new Error('Falha ao buscar dados do Shields.io');
            const data = await response.json();
            const newCount = `+${data.value}`;
            const descriptionElement = document.getElementById('botania-description');
            if (descriptionElement) {
                descriptionElement.textContent = `Biblioteca Java open-source desenvolvida para habilitar interoperabilidade entre sistemas de transporte de fluidos de terceiros e o Petal Apothecary do Botania. Atingiu ${newCount} downloads na CurseForge com ~50.000 usuários ativos diários.`;
            }
        } catch (error) {
            console.warn('Falha ao atualizar downloads ao vivo:', error.message);
        }
    }
    document.addEventListener('DOMContentLoaded', fetchCurseForgeDownloads);
    </script>
</Layout>
