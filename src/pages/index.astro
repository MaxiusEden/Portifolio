---
// Importa o Layout principal e os componentes
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import Skills from '../components/Skills.astro';
---

<Layout title="Filipe Machado | Desenvolvedor de Software">
	<main class="container mx-auto px-4">
		<section class="hero text-center py-24 sm:py-36">
			<h1 class="text-5xl sm:text-7xl font-black tracking-tighter bg-clip-text text-transparent bg-gradient-to-r from-white to-gray-500">
				Filipe Pereira Machado
			</h1>
			<p class="text-xl sm:text-2xl mt-4 text-gray-300">Desenvolvedor Java e Criador de Soluções Inovadoras</p>
			<p class="max-w-2xl mx-auto mt-6 text-gray-400">
				Apaixonado por soluções tecnológicas com foco em performance e eficiência. Proficiente em controlo de versão, desenvolvimento modular e práticas de engenharia de software.
			</p>
			<div class="mt-10 flex flex-col sm:flex-row justify-center gap-4">
				<a href="#projetos" class="bg-cyan-400 text-gray-900 font-bold py-3 px-8 rounded-lg hover:bg-cyan-300 transition-all duration-300 transform hover:scale-105">
					Ver Projetos
				</a>
				<a href="mailto:filipepm17@gmail.com" class="bg-gray-800/50 border border-gray-700 text-gray-200 font-bold py-3 px-8 rounded-lg hover:bg-gray-700 hover:border-gray-600 transition-all duration-300">
					Entrar em Contato
				</a>
			</div>
		</section>

		<Skills />

		<section id="projetos" class="py-24">
			<h2 class="text-4xl sm:text-5xl font-bold text-center mb-16">Projetos em Destaque</h2>
			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
				
				<ProjectCard
					title="Mod BotaniaTubes (Addon para Botania)"
					description="Addon para o mod Botania que permite automação completa do Petal Apothecary. Atingiu +50.000 downloads e recebeu feedback positivo da comunidade no CurseForge."
					tags={['Java', 'Minecraft Forge', 'Gradle']}
					githubUrl="https://github.com/MaxiusEden/BotaniaTubes"
					liveUrl="https://www.curseforge.com/minecraft/mc-mods/botaniatubes"
					imageUrl="/projeto-botaniatubes.png"  
				/>

				<ProjectCard
					title="Aplicativo de Orçamento Municipal"
					description="Ferramenta para visualização de dados de auxílio municipal com gráficos interativos (Chart.js) e armazenamento local. Design responsivo e acessível."
					tags={['JavaScript', 'HTML', 'CSS', 'Chart.js']}
					githubUrl="https://github.com/MaxiusEden/Aplicativo-de-Or-amento-Municipal"
					liveUrl="#"
					imageUrl="/projeto-orcamento.png" 
				/>

				<ProjectCard
					title="Protótipo de Jogo 2D em Unity"
					description="Side-scroller com mecânicas de coleta de itens, estados de vitória e colisões. Programado em C# com gestão de cenas e pooling de objetos."
					tags={['C#', 'Unity 2D']}
					githubUrl="https://github.com/MaxiusEden/Prot-tipo-de-Jogo-2D-em-Unity"
					liveUrl="#"
					imageUrl="/projeto-jogo2d.png"
				/>

			</div>
		</section>
	</main>
</Layout>