---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import Skills from '../components/Skills.astro';

// --- INÍCIO DA LÓGICA DE DIAGNÓSTICO ---

const apiKey = import.meta.env.CURSEFORGE_API_KEY;
const modId = 1183923;

let downloadCountFormatted = "+50.000"; // Valor padrão

// Verificação inicial da API Key no log
console.log(`A usar a API Key que termina em: ${apiKey ? apiKey.slice(-4) : 'NENHUMA'}`);

try {
  const response = await fetch(`https://api.curseforge.com/v1/mods/${modId}`, {
    headers: {
      'Content-Type': 'application/json',
      'x-api-key': apiKey
    }
  });

  // Log para vermos a resposta da API
  console.log(`Resposta da API do CurseForge: Status ${response.status} ${response.statusText}`);

  if (response.ok) {
    const data = await response.json();
    const downloadCount = data.data.downloadCount;
    downloadCountFormatted = `+${downloadCount.toLocaleString('pt-BR')}`;
    console.log(`Sucesso! Downloads encontrados: ${downloadCount}`);
  } else {
    // Log se a resposta não for OK
    console.error(`Resposta da API não foi OK. Status: ${response.status}`);
    const errorBody = await response.text();
    console.error(`Corpo da resposta de erro: ${errorBody}`);
  }

} catch (error) {
  console.error("ERRO CRÍTICO ao tentar fazer o fetch:", error);
}

const botaniaTubesDescription = `Addon para o mod Botania que permite automação completa do Petal Apothecary. Atingiu ${downloadCountFormatted} downloads e recebeu feedback positivo da comunidade no CurseForge.`;

// --- FIM DA LÓGICA ---
---

