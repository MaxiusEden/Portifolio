---
import { Icon } from 'astro-icon/components';

const skills = {
    "Linguagens": [
        { name: "Java", icon: "devicon:java" },
        { name: "TypeScript", icon: "devicon:typescript" },
        { name: "JavaScript", icon: "devicon:javascript" },
        { name: "Python", icon: "devicon:python" },
        { name: "Kotlin", icon: "devicon:kotlin" },
        { name: "C#", icon: "devicon:csharp" }
    ],
    "Frameworks & Ferramentas": [
        { name: "Spring Boot", icon: "devicon:spring" },
        { name: "React", icon: "devicon:react" },
        { name: "Next.js", icon: "devicon:nextjs" },
        { name: "Android SDK", icon: "devicon:android" },
        { name: "Supabase", icon: "devicon:supabase" },
        { name: "PostgreSQL", icon: "devicon:postgresql" },
        { name: "Docker", icon: "devicon:docker" },
        { name: "Git", icon: "devicon:git" }
    ],
    "Práticas": [
        { name: "Clean Code / SOLID", icon: "mdi:code-braces-box" },
        { name: "Design Patterns", icon: "mdi:package-variant-closed" },
        { name: "REST APIs", icon: "mdi:api" },
        { name: "CI/CD (GitHub Actions)", icon: "mdi:source-branch" },
        { name: "Metodologias Ágeis", icon: "mdi:human-male-board" }
    ]
};
---

<section id="habilidades" class="py-20 my-24 bg-gray-800/30 border-y border-gray-700/50">
    <div class="container mx-auto px-4">
        <h2 class="text-4xl sm:text-5xl font-bold text-center mb-16">Habilidades Técnicas</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12 text-center">
            {Object.entries(skills).map(([category, items]) => (
                <div>
                    <h3 class="text-2xl font-bold text-cyan-400 mb-6">{category}</h3>
                    <ul class="space-y-4">
                        {items.map(item => (
                            <li class="flex items-center justify-center gap-3 text-gray-300 text-lg">
                                <Icon name={item.icon} class="h-6 w-6" />
                                <span>{item.name}</span>
                            </li>
                        ))}
                    </ul>
                </div>
            ))}
        </div>
    </div>
</section>
